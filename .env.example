# =============================================================================
# Plantilla de variables de entorno para PRODUCCION
# Copiar a .env y completar:  cp .env.example .env
# El archivo .env NO debe versionarse (ya esta en .gitignore).
# Lo usa docker-compose.prod.yml (env_file).
# =============================================================================

# --- Imagenes (FIJAR versiones en produccion, no usar latest) ---------------
INDICO_IMAGE=ghcr.io/indico/indico:3.3
POSTGRES_IMAGE=postgres:15
REDIS_IMAGE=redis:7

# --- Base de datos -----------------------------------------------------------
PGHOST=postgres
PGPORT=5432
PGUSER=indico
PGDATABASE=indico
# Generar una password fuerte:  openssl rand -base64 24
PGPASSWORD=CAMBIAR_password_postgres_fuerte

# --- Identidad / URL ---------------------------------------------------------
# Generar con:  python -c "import secrets; print(secrets.token_hex(32))"
INDICO_SECRET_KEY=CAMBIAR_secret_key_64_hex
# Dominio real con https (lo termina nginx con TLS)
INDICO_BASE_URL=https://eventos.tudominio.com
# True porque Indico corre detras de un proxy inverso (nginx)
INDICO_USE_PROXY=true

INDICO_DEFAULT_TIMEZONE=America/Argentina/Buenos_Aires
INDICO_DEFAULT_LOCALE=es_ES

# --- Puerto local del contenedor web (solo loopback, lo consume nginx) -------
# Se publica como 127.0.0.1:${INDICO_HTTP_BIND}:59999
INDICO_HTTP_BIND=8000

# --- Correo (SMTP real) ------------------------------------------------------
INDICO_NO_REPLY_EMAIL=noreply@tudominio.com
INDICO_SUPPORT_EMAIL=soporte@tudominio.com
INDICO_SMTP_HOST=smtp.tudominio.com
INDICO_SMTP_PORT=587
INDICO_SMTP_USE_TLS=true
INDICO_SMTP_USE_SSL=false
INDICO_SMTP_LOGIN=noreply@tudominio.com
INDICO_SMTP_PASSWORD=CAMBIAR_password_smtp

# --- Funcionalidades ---------------------------------------------------------
INDICO_ENABLE_ROOMBOOKING=true
